# ─────────────────────────────────────────────
# MKT-AI — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real no repositório
# ─────────────────────────────────────────────

# ── LLM ──────────────────────────────────────
# Provedor ativo: "groq" ou "anthropic"
LLM_PROVIDER=anthropic

# Anthropic (recomendado)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq (fallback)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Busca web ─────────────────────────────────
# Provedor ativo: "tavily" ou "anthropic"
SEARCH_PROVIDER=anthropic

# Tavily (usado quando SEARCH_PROVIDER=tavily)
TAVILY_API_KEY=tvly-...

# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...

# ── Meta Marketing API ────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_...

# ── Instagram Graph API ───────────────────────
# Mesmo token do Meta se tiver permissões instagram_basic e instagram_manage_insights
INSTAGRAM_ACCOUNT_ID=

# ── Alertas e sistema ─────────────────────────
API_TOKEN=senha-forte-aqui
ENV=development
LOG_FILE=logs/execucoes.jsonl

# ── Performance ───────────────────────────────
# CPL acima deste valor dispara alerta (em R$)
CPL_LIMITE_ALERTA=50